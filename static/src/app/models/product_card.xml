<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-information-tag')]" position="before">
            <t t-if="pos.config.show_product_qty">
                <t t-if="value.show_qty">
                    <div class="ribbon"
                         t-att-class="{'text-danger': state.avail_qty &lt;= 0,'text-success': state.avail_qty &gt; 0}">
                        <t t-out="state.avail_qty"/>
                    </div>
                </t>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('product-content')]" position="after">
            <div class="d-flex px-2 pb-1">
                <span class="fw-bold text-primary small">
                    <t t-esc="productPriceTTC"/>
                </span>
            </div>
        </xpath>
    </t>
</templates>